# DeepSeek 的 OpenAI 兼容 API 地址。
# 官方文档目前使用 https://api.deepseek.com。
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 这里填你自己的 DeepSeek API Key。
# 注意：真实 Key 只放在 .env 里，不要提交到 Git。
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# DeepSeek 模型名。
# 你可以在官方文档中查看当前支持的模型，并在这里替换。
DEEPSEEK_MODEL=deepseek-v4-flash

# FastAPI 本地服务监听地址和端口。
# 127.0.0.1 表示只允许本机访问，适合学习和本地开发。
APP_HOST=127.0.0.1
APP_PORT=8000

# Agent 最多允许模型和工具来回交互几轮。
# 设上限是为了避免模型不断调用工具导致死循环。
AGENT_MAX_STEPS=5

# Agent 事件日志文件。默认写到 logs/，这个目录不会提交到 Git。
AGENT_LOG_PATH=logs/agent-events.jsonl
